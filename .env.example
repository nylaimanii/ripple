# Copy this file to .env and fill in your values

# Groq — scenario generation engine. Get your key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Mapbox — free tier at mapbox.com
# Get your public access token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_public_access_token_here

# Supabase — free tier at supabase.com
# Find these in your project at: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Gemini — for Historical Verdict + Journal insights (Google AI Studio, free tier)
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# K2 Think V2 — core reasoning engine for scenario generation
# 70B reasoning model purpose-built for multi-step problem solving
# Get your key at: https://k2think.ai
VITE_K2_API_KEY=your_k2_api_key_here
