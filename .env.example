# Copy this file to .env and fill in your values

# Mapbox — free tier at mapbox.com
# Get your public access token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_public_access_token_here

# Supabase — free tier at supabase.com
# Find these in your project at: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# ElevenLabs — for voiceover (plug in after hackathon)
# Get your key at: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
